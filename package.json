{
  "name": "bookmarks-manager",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"HTTP_PORT=8787 tsx watch src/main.ts\" \"vite --config web/vite.config.ts --port 5173\"",
    "build": "vite build --config web/vite.config.ts && tsup",
    "start": "node dist/main.js",
    "pm2:start": "pnpm build && pm2 start ecosystem.config.cjs --env production",
    "pm2:restart": "pm2 restart bookmarks-manager",
    "pm2:stop": "pm2 stop bookmarks-manager && pm2 delete bookmarks-manager",
    "pm2:logs": "pm2 logs bookmarks-manager",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate-cli.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "biome:check": "biome check .",
    "biome:format": "biome format --write ."
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.12",
    "@fastify/static": "^9.1.1",
    "@mozilla/readability": "^0.5.0",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.0",
    "grammy": "^1.34.0",
    "jsdom": "^25.0.1",
    "openai": "^4.77.0",
    "p-queue": "^8.0.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.59.1",
    "react-markdown": "^10.1.0",
    "telegramify-markdown": "^1.3.3",
    "youtubei.js": "^11.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.30.1",
    "pm2": "^7.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
